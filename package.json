{
  "name": "voltaire-desktop",
  "version": "2.0.0",
  "description": "Voltaire — French learning desktop shell (Electron + Next.js + FastAPI)",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "desktop": "electron .",
    "desktop:dev": "electron .",
    "desktop:build-frontend": "cd frontend && npm run build",
    "dist:mac": "npm run desktop:build-frontend && electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.voltaire.desktop",
    "productName": "Voltaire",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/**/*",
      "package.json",
      "!**/.env",
      "!**/.env.*",
      "!**/cato_mind.db",
      "!logs/**",
      "!.git/**",
      "!frontend/.next/cache/**",
      "!**/*.log"
    ],
    "mac": {
      "icon": "build/Voltaire.icns",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.education"
    }
  }
}
